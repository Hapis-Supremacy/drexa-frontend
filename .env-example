# Backend API base URL — change to your production URL when deploying
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Realtime price stream — backend market WebSocket (Go gateway). Use wss:// in production.
NEXT_PUBLIC_WS_URL=ws://localhost:8080/api/v1/market/ws

# Realtime candle / bar chart — Binance public market-data endpoints (no API key needed)
NEXT_PUBLIC_BINANCE_REST_URL=https://data-api.binance.vision/api/v3
NEXT_PUBLIC_BINANCE_WS_URL=wss://data-stream.binance.vision/ws

# Firebase configuration
# Copy this file to .env and fill in your project's values from the Firebase Console:
# https://console.firebase.google.com → Project Settings → Your apps → SDK setup and configuration

NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Stripe — get from Stripe Dashboard → API keys (Publishable key)
# Secret key and webhook secret live in the Go backend .env only — never expose here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...